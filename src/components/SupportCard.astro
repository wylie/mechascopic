---
export interface Props {
  siteName?: string;
  heading?: string;
  description?: string;
  compact?: boolean;
}

const {
  siteName = "Mechascopic",
  heading = `Support ${siteName}`,
  description = "If the guides and videos help you, you can support future posts here.",
  compact = false,
} = Astro.props;
---

<aside class={`support-card${compact ? " support-card--compact" : ""}`} aria-label={`Support ${siteName}`}>
  <h2>{heading}</h2>
  {description && <p>{description}</p>}
  <div class="support-button-wrap">
    <script type="text/javascript" src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js" data-name="bmc-button" data-slug="Wylie" data-color="#ffb703" data-emoji="☕"  data-font="Cookie" data-text="Buy me a tea" data-outline-color="#000000" data-font-color="#000000" data-coffee-color="#FFDD00" ></script>
  </div>
</aside>

<style>
  .support-card {
    margin: 1.5rem 0;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-alt);
  }

  .support-card h2 {
    margin: 0 0 0.45rem;
    font-size: 1.1rem;
    color: var(--color-fg);
  }

  .support-card p {
    margin: 0 0 0.85rem;
    font-size: 0.95rem;
  }

  .support-card--compact {
    padding: 0.8rem 0.9rem;
    margin: 1.1rem 0;
  }

  .support-card--compact h2 {
    margin-bottom: 0.3rem;
    font-size: 1rem;
  }

  .support-card--compact p {
    margin-bottom: 0.6rem;
    font-size: 0.9rem;
  }

  .support-button-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 44px;
  }

  @media (max-width: 600px) {
    .support-card {
      margin: 1.25rem 0;
      padding: 0.9rem;
    }
  }
</style>
