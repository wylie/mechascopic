---
// Layout: Base site layout for Mechascopic
import { SITE } from "../config";
const base = import.meta.env.BASE_URL;
const gaMeasurementId = SITE.gaMeasurementId;
const shouldLoadGa = !!gaMeasurementId;
const canonicalUrl = new URL(Astro.url.pathname, SITE.url).toString();

const normalizePath = (value: string): string => {
  const trimmed = value.replace(/\/+$/, "");
  return trimmed.length > 0 ? trimmed : "/";
};

const currentPath = normalizePath(Astro.url.pathname);

const navLinks = [
  { href: base, label: "Home", exact: true },
  { href: `${base}guides`, label: "Guides" },
  { href: `${base}newsletter`, label: "Newsletter" },
  { href: `${base}gear`, label: "Gear" },
  { href: `${base}about`, label: "About" },
  { href: `${base}contact`, label: "Contact" },
];

const isNavLinkActive = (href: string, exact = false): boolean => {
  const normalizedHref = normalizePath(href);
  if (exact) {
    return currentPath === normalizedHref;
  }

  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
};

const activeNavLinkStyle =
  "color: var(--color-accent); text-decoration: underline; text-underline-offset: 0.22em; text-decoration-thickness: 2px;";
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title ? Astro.props.title + ' | ' + SITE.name : SITE.name}</title>
    <meta name="description" content={Astro.props.description || SITE.description} />
    <link rel="canonical" href={canonicalUrl} />
    {shouldLoadGa && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
        <script is:inline define:vars={{ gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          const host = window.location.hostname;
          const isLocalHost = host === 'localhost' || host === '127.0.0.1';
          const isVercelHost = host === 'mechascopic.vercel.app' || host.endsWith('.vercel.app');
          if (!isLocalHost && !isVercelHost) {
            gtag('config', gaMeasurementId, { page_path: window.location.pathname });
          }
        </script>
      </>
    )}
    {import.meta.env.DEV && !shouldLoadGa && (
      <script is:inline>
        console.warn("[GA] PUBLIC_GA_MEASUREMENT_ID is missing. GA4 tracking is disabled.");
      </script>
    )}
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header>
      <nav>
        {navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={isNavLinkActive(link.href, link.exact) ? "page" : undefined}
            style={isNavLinkActive(link.href, link.exact) ? activeNavLinkStyle : undefined}
          >
            {link.label}
          </a>
        ))}
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} Mechascopic. All rights reserved.</p>
      <p class="footer-links">
        <a href={`${base}privacy`}>Privacy</a>
        <span aria-hidden="true"> · </span>
        <a href={`${base}disclosure`}>Disclosure</a>
      </p>
    </footer>
  </body>
</html>

<style>
  /*
    Global stylesheet for Mechascopic
    - Mobile-first, dark mode, accessible
    - Clean, readable typography
    - Polished buttons, nav, spacing, cards
  */
  :root {
    --color-bg: #181a1b;
    --color-bg-alt: #232527;
    --color-fg: #f3f4f6;
    --color-accent: #4fd1c5;
    --color-on-accent: #181a1b;
    --color-link: #7dd3fc;
    --color-link-hover: #38bdf8;
    --color-border: #2d2f31;
    --font-main: 'Inter', system-ui, sans-serif;
    --font-mono: 'Fira Mono', monospace;
    --radius: 8px;
    --control-height: 2.7rem;
    --transition: 0.15s cubic-bezier(.4,0,.2,1);
  }
  html {
    background: var(--color-bg);
    color: var(--color-fg);
    font-family: var(--font-main);
    font-size: 18px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    scroll-behavior: smooth;
  }
  *, *::before, *::after {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-fg);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  a {
    color: var(--color-link);
    text-decoration: underline;
    transition: color var(--transition);
  }
  a:hover {
    color: var(--color-link-hover);
  }
  header {
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
    padding: 0.5rem 0;
  }
  header nav {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    font-size: 1.1rem;
    padding: 0.5rem 0;
  }
  header nav a {
    color: var(--color-link);
    text-decoration: none;
    font-weight: 500;
    padding: 0.25em 0.5em;
    border-radius: var(--radius);
    transition: background var(--transition), color var(--transition);
  }
  header nav a:hover, header nav a:focus {
    background: var(--color-accent);
    color: var(--color-on-accent);
  }
  footer {
    background: var(--color-bg-alt);
    border-top: 1px solid var(--color-border);
    text-align: center;
    padding: 1.5rem 0 1rem 0;
    font-size: 0.95rem;
  }
  .footer-links {
    margin: 0.5rem 0 0;
  }
  .footer-links a {
    text-decoration: underline;
  }
  main {
    flex: 1;
    width: 100%;
    max-width: 720px;
    margin: 2.5rem auto 0 auto;
    padding: 2rem 1.25rem 3rem 1.25rem;
  }
  section {
    margin-bottom: 2.5rem;
  }
  h1, h2, h3 {
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 0.75em;
    letter-spacing: -0.01em;
  }
  h1 {
    font-size: 2.2rem;
  }
  h2 {
    font-size: 1.4rem;
    color: var(--color-accent);
  }
  h3 {
    font-size: 1.1rem;
  }
  button, input, select, textarea {
    font-family: inherit;
    font-size: 1rem;
  }
  img, video {
    max-width: 100%;
    border-radius: var(--radius);
  }
  .skip-link {
    position: absolute;
    left: -999px;
    top: auto;
    width: 1px;
    height: 1px;
    overflow: hidden;
    z-index: 100;
    background: var(--color-accent);
    color: var(--color-on-accent);
    padding: 0.5em 1em;
    border-radius: var(--radius);
    transition: left var(--transition);
  }
  .skip-link:focus {
    left: 1rem;
    top: 1rem;
    width: auto;
    height: auto;
    outline: 2px solid var(--color-accent);
  }
  @media (prefers-color-scheme: light) {
    :root {
      --color-bg: #f3f4f6;
      --color-bg-alt: #e5e7eb;
      --color-fg: #181a1b;
      --color-accent: #0f766e;
      --color-on-accent: #ffffff;
      --color-link: #2563eb;
      --color-link-hover: #1d4ed8;
      --color-border: #d1d5db;
    }
    header, footer {
      background: var(--color-bg-alt);
      border-bottom: 1px solid var(--color-border);
    }
  }
  /* Focus states */
  :focus {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 480px) {
    header nav {
      gap: 0.5rem 0.75rem;
      font-size: 1rem;
      padding: 0.4rem 0.6rem;
    }

    header nav a {
      padding: 0.2em 0.4em;
    }

    main {
      margin-top: 1.25rem;
      padding: 1.25rem 0.9rem 2rem;
    }
  }
</style>