---
import Layout from "../../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { readdir } from "node:fs/promises";
import { SITE } from "../../config";
import { getBeehiivPostsFromRss, type BeehiivPostItem } from "../../lib/beehiivFeed";

async function getPublishedIssues() {
  const contentDir = new URL("../../content/newsletter", import.meta.url);

  try {
    const entries = await readdir(contentDir, { withFileTypes: true });
    const hasMarkdownFiles = entries.some((entry) => entry.isFile() && /\.(md|mdx)$/i.test(entry.name));

    if (!hasMarkdownFiles) {
      return [];
    }

    return await getCollection("newsletter", ({ data }) => !data.draft);
  } catch {
    return [];
  }
}

const slug = String(Astro.params.slug ?? "");
const issues: CollectionEntry<"newsletter">[] = await getPublishedIssues();
const localIssue = issues.find((issue) => issue.slug === slug) ?? null;

let beehiivPost: BeehiivPostItem | null = null;
if (!localIssue) {
  const beehiivPosts = await getBeehiivPostsFromRss(SITE.newsletter.beehiivRssUrl, 250);
  beehiivPost = beehiivPosts.find((post) => String(post.issueNumber) === slug) ?? null;
}

if (!localIssue && !beehiivPost) {
  Astro.response.status = 404;
}

const isLocal = Boolean(localIssue);
const isFound = Boolean(localIssue || beehiivPost);
const contentResult = localIssue ? await localIssue.render() : null;
const Content = contentResult?.Content;

const publishedDate = (isLocal ? localIssue?.data.pubDate : beehiivPost?.pubDate)?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
}) ?? "";

const updatedDate = isLocal && localIssue?.data.updatedDate
  ? localIssue.data.updatedDate.toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;
---

<Layout
  title={`${isFound ? (isLocal ? localIssue?.data.title : beehiivPost?.title) : "Newsletter Not Found"} | Newsletter`}
  description={isFound ? (isLocal ? localIssue?.data.description : beehiivPost?.excerpt || beehiivPost?.title) : "This newsletter issue was not found."}
>
  <main>
    {isFound ? (
      <article>
        <p class="back-link-wrap">
          <a class="back-link" href="/newsletter">Back to Newsletter Archive</a>
        </p>

        <header class="issue-header">
          <p class="eyebrow">
            {isLocal
              ? `Mechascopic's Dispatch · Issue #${localIssue?.data.issueNumber} · ${publishedDate}`
              : `Mechascopic's Dispatch #${beehiivPost?.issueNumber} · ${publishedDate}`}
            {isLocal && updatedDate && <span> · Updated {updatedDate}</span>}
          </p>
          <h1>{isLocal ? localIssue?.data.title : beehiivPost?.title}</h1>
          {isLocal ? <p>{localIssue?.data.description}</p> : null}
          {isLocal && localIssue?.data.beehiivUrl && (
            <p>
              <a href={localIssue.data.beehiivUrl} target="_blank" rel="noopener noreferrer">Also view this issue on Beehiiv</a>
            </p>
          )}
        </header>

        {isLocal && Content ? <Content /> : <section class="issue-content" set:html={beehiivPost?.contentHtml} />}
      </article>
    ) : (
      <article>
        <h1>Issue Not Found</h1>
        <p>That newsletter issue is not available yet. Check back in a minute or open the archive.</p>
        <p class="back-link-wrap">
          <a class="back-link" href="/newsletter">Back to Newsletter Archive</a>
        </p>
      </article>
    )}
  </main>
</Layout>

<style>
  .issue-header {
    margin-bottom: 1.5rem;
  }

  .back-link-wrap {
    margin-bottom: 1rem;
  }

  .back-link {
    text-decoration: none;
    font-size: 0.95rem;
  }

  .back-link,
  .back-link:visited {
    color: var(--color-link);
  }

  .back-link:hover,
  .back-link:focus {
    color: var(--color-link-hover);
  }

  .eyebrow {
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 0.5rem;
  }

  article :global(a),
  article :global(a:visited) {
    color: var(--color-accent);
  }

  article :global(a:hover),
  article :global(a:focus) {
    color: var(--color-link-hover);
  }

  .issue-content :global(p) {
    margin: 0 0 1rem;
  }
</style>
