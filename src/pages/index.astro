---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import FeaturedVideos from "../components/FeaturedVideos.astro";
import GuidesList from "../components/GuidesList.astro";
import AdSlot from "../components/AdSlot.astro";
const base = import.meta.env.BASE_URL;
const guidesHref = base + "guides";
const gearHref = base + "gear";
const newsletterSubscribeHref = "https://mechascopic.beehiiv.com";
---

<Layout title="Mechascopic, chill gameplay and guides." description="Guides, gear, and chill gameplay content. Subscribe for the latest videos and live streams.">
  <main>
    <section class="hero">
      <h1>Mechascopic, chill gameplay and guides.</h1>
      <p>Guides, gear, and chill gameplay content. Subscribe for the latest videos and live streams.</p>
      <p>Mechascopic covers practical PvE gaming guides, build ideas, and creator-tested setup recommendations for players who want steady improvement without the stress.</p>
      <div class="cta-row">
        <Button href="https://youtube.com/@mechascopic" text="Subscribe on YouTube" target="_blank" />
        <Button href={guidesHref} text="Latest Guides" />
        <Button href={gearHref} text="Gear I Use" />
      </div>
    </section>

    <AdSlot label="Home, below hero" minHeight="110px" />

    <section>
      <h2>Latest Guides</h2>
      <p>Browse recent strategy posts for Destiny 2 and other PvE-focused games, including beginner-friendly tips, class builds, and efficient loadout ideas.</p>
      <GuidesList />
    </section>

    <FeaturedVideos />

    <AdSlot label="Home, below videos" minHeight="140px" />

    <section>
      <h2>Newsletter</h2>
      <p>Get updates when new gameplay guides, video breakdowns, and gear recommendations are published.</p>
      <div class="newsletter-card">
        <h3>Subscribe to Mechascopic's Dispatch</h3>
        <p>
          Mechascopic's Dispatch is now live on Beehiiv with practical gameplay notes, guide highlights,
          and creator updates delivered every two weeks.
        </p>
        <p>
          <a class="newsletter-link" href={newsletterSubscribeHref} target="_blank" rel="noopener noreferrer">
            Join on Beehiiv
          </a>
        </p>
        <div class="cta-row">
          <Button href={newsletterSubscribeHref} text="Subscribe to Dispatch" target="_blank" />
          <Button href="https://youtube.com/@mechascopic" text="Follow on YouTube" target="_blank" />
          <Button href={guidesHref} text="Browse Guides" />
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 1.5rem;
  }

  .newsletter-card {
    margin-top: 1rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg-alt);
  }

  .newsletter-card h3 {
    margin-bottom: 0.5rem;
  }

  .newsletter-link {
    color: var(--color-accent);
  }

  .newsletter-card .cta-row {
    margin-top: 1rem;
    justify-content: flex-start;
  }
</style>