---
import Layout from "../layouts/Layout.astro";
import AffiliateDisclosure from "../components/AffiliateDisclosure.astro";
import GearList from "../components/GearList.astro";
import SupportCard from "../components/SupportCard.astro";
---

<Layout title="Gear I Use | Mechascopic" description="My setup and recommended alternatives for PvE gaming.">
  <main>
    <h1>My Setup & Recommended Gear</h1>
    <p>This page lists the gaming gear and creator tools I currently use for PvE gameplay, streaming, and recording, plus reliable alternatives at different budgets.</p>
    <AffiliateDisclosure />
    <GearList />
    <p>Every recommendation is selected for comfort, consistency, and value over long sessions.</p>
    <SupportCard compact={true} description="If these recommendations are helpful, you can support future gear updates here." />
  </main>
</Layout>
